# Caddyfile — Reverse-Proxy for STT-Server
#
# Development: uses Caddy's internal CA (self-signed certs)
# Production:  set SITE_ADDRESS to your domain for automatic Let's Encrypt
#
# Environment variables (set in .env or docker-compose.yml):
#   SITE_ADDRESS  — Domain or localhost (default: localhost = self-signed)

{
	ocsp_stapling off
	default_sni {$SITE_ADDRESS:localhost}
}

{$SITE_ADDRESS:localhost} {
	# --- TLS: internal CA for IPs / localhost ---
	tls internal

	# --- Security Headers (OWASP Best Practices) ---
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "microphone=(), camera=(), geolocation=()"
		-Server
	}

	# --- Request size limit (500 MB for audio uploads) ---
	request_body {
		max_size 500MB
	}

	# --- Reverse-Proxy to Gunicorn ---
	reverse_proxy stt-server:8090 {
		# Pass original client info (Zero-Trust)
		header_up X-Forwarded-Proto {scheme}
		header_up X-Real-IP {remote_host}

		# Health check
		health_uri /health
		health_interval 30s
		health_timeout 5s
	}

	# --- Logging ---
	log {
		output stdout
		format console
		level INFO
	}
}
