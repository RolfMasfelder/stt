# STT Project Configuration - Production Example
# Copy this file to .env and adjust values as needed

# LM Studio Configuration
LM_STUDIO_HOST=lmstudio
LM_STUDIO_PORT=1234

# LM Studio Model Configuration
LM_STUDIO_MODEL=mistral-7b-instruct
LM_STUDIO_TIMEOUT=120

# Audio Processing Configuration
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_TIMEOUT=600

# Remote Whisper Server (optional)
# Set this to offload transcription to a remote faster-whisper-server instance.
# When unset, transcription runs locally.
# WHISPER_API_URL=http://192.168.178.80:8000/v1/audio/transcriptions

# HuggingFace Token for pyannote speaker diarization
HF_STT_TOKEN=your_huggingface_token_here

# Application Configuration
LOG_LEVEL=INFO

# File Paths (relative to project root)
AUDIO_INPUT_DIR=./audio
OUTPUT_DIR=./output

# Caddy Reverse-Proxy / TLS Configuration
# Set to your domain for production (automatic Let's Encrypt)
# Default :443 uses Caddy's internal CA (self-signed, for development)
# SITE_ADDRESS=stt.example.com

# Django Security
# DJANGO_SECRET_KEY=change-me-in-production
# DEBUG=false
# ALLOWED_HOSTS=stt.example.com

# Production Settings
DEVELOPMENT_MODE=false
DEBUG=false
