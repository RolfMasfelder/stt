# STT Project Configuration - Production Example
# Copy this file to .env and adjust values as needed

# LLM Configuration (Ollama)
# For local Ollama: http://ollama:11434 (Docker) or http://localhost:11434
# For remote Ollama (dev): http://192.168.178.80:11434
LLM_BASE_URL=http://ollama:11434
LLM_MODEL=mistral
LLM_TIMEOUT=120

# Audio Processing Configuration
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_TIMEOUT=600

# ML Service Configuration
# The ML microservice handles transcription (faster-whisper) and
# speaker diarization (pyannote). Runs as a separate container.
ML_SERVICE_URL=http://stt-ml:8091
ML_SERVICE_TIMEOUT=600

# HuggingFace Token for pyannote speaker diarization (used by ML service)
HF_STT_TOKEN=your_huggingface_token_here

# Application Configuration
LOG_LEVEL=INFO

# File Paths (relative to project root)
AUDIO_INPUT_DIR=./audio
OUTPUT_DIR=./output

# --- OAuth2 Client Credentials (for CLI/remote access, ADR-07) ---
# Required when connecting to a remote STT server with OAuth2 enabled.
# Create an application in Django admin or via /o/applications/ first.
# STT_SERVER_URL=https://stt.example.com
# OAUTH2_CLIENT_ID=your_client_id_here
# OAUTH2_CLIENT_SECRET=your_client_secret_here
# OAUTH2_TOKEN_URL=https://stt.example.com/o/token/
# OAUTH2_SCOPES=read write

# Caddy Reverse-Proxy / TLS Configuration
# Set to your domain for production (automatic Let's Encrypt)
# Default :443 uses Caddy's internal CA (self-signed, for development)
# SITE_ADDRESS=stt.example.com

# Django Security
# DJANGO_SECRET_KEY=change-me-in-production
# DEBUG=false
# ALLOWED_HOSTS=stt.example.com

# Production Settings
DEVELOPMENT_MODE=false
DEBUG=false
