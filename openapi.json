{
  "openapi": "3.0.3",
  "info": {
    "title": "STT Server API",
    "version": "1.0.0",
    "description": "Speech-to-Text Server mit Transkription, Sprechererkennung und Zusammenfassung"
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health_retrieve",
        "summary": "Health check",
        "tags": [
          "health"
        ],
        "security": [
          {}
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/v1/config/storage": {
      "get": {
        "operationId": "v1_config_storage_list",
        "description": "List and create storage backend configurations.",
        "summary": "List all storage configurations",
        "tags": [
          "v1"
        ],
        "security": [
          {
            "oauth2": [
              "read"
            ]
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/StorageConfig"
                  }
                }
              }
            },
            "description": ""
          }
        }
      },
      "post": {
        "operationId": "v1_config_storage_create",
        "description": "List and create storage backend configurations.",
        "summary": "Create a storage configuration",
        "tags": [
          "v1"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/StorageConfig"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/StorageConfig"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StorageConfig"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageConfig"
                }
              }
            },
            "description": ""
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/v1/config/storage/{config_id}": {
      "get": {
        "operationId": "v1_config_storage_retrieve",
        "description": "Retrieve, update, and delete a storage backend configuration.",
        "summary": "Get a storage configuration",
        "parameters": [
          {
            "in": "path",
            "name": "config_id",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ],
        "tags": [
          "v1"
        ],
        "security": [
          {
            "oauth2": [
              "read"
            ]
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageConfig"
                }
              }
            },
            "description": ""
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      },
      "put": {
        "operationId": "v1_config_storage_update",
        "description": "Retrieve, update, and delete a storage backend configuration.",
        "summary": "Update a storage configuration",
        "parameters": [
          {
            "in": "path",
            "name": "config_id",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ],
        "tags": [
          "v1"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/StorageConfig"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/StorageConfig"
              }
            },
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/StorageConfig"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageConfig"
                }
              }
            },
            "description": ""
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      },
      "delete": {
        "operationId": "v1_config_storage_destroy",
        "description": "Retrieve, update, and delete a storage backend configuration.",
        "summary": "Delete a storage configuration",
        "parameters": [
          {
            "in": "path",
            "name": "config_id",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ],
        "tags": [
          "v1"
        ],
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "responses": {
          "204": {
            "description": "No response body"
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/v1/config/storage/{config_id}/test": {
      "post": {
        "operationId": "v1_config_storage_test_create",
        "description": "Test a storage backend configuration (ADR-12).",
        "summary": "Test storage backend connectivity",
        "parameters": [
          {
            "in": "path",
            "name": "config_id",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ],
        "tags": [
          "v1"
        ],
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StorageTestResponse"
                }
              }
            },
            "description": ""
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/v1/diarize": {
      "post": {
        "operationId": "v1_diarize_create",
        "summary": "Transcribe with speaker diarization",
        "tags": [
          "v1"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/AudioUpload"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/AudioUpload"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DiarizeResponse"
                }
              }
            },
            "description": ""
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          },
          "413": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/v1/jobs": {
      "post": {
        "operationId": "v1_jobs_create",
        "description": "Upload an audio file and create an async job. Poll GET /v1/jobs/{id} for status and results.",
        "summary": "Create async processing job",
        "tags": [
          "v1"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ProcessUpload"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/ProcessUpload"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobResponse"
                }
              }
            },
            "description": ""
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          },
          "413": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/v1/jobs/{job_id}": {
      "get": {
        "operationId": "v1_jobs_retrieve",
        "summary": "Get job status and results",
        "parameters": [
          {
            "in": "path",
            "name": "job_id",
            "schema": {
              "type": "string"
            },
            "required": true
          }
        ],
        "tags": [
          "v1"
        ],
        "security": [
          {
            "oauth2": [
              "read"
            ]
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/JobDetail"
                }
              }
            },
            "description": ""
          },
          "404": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/v1/process": {
      "post": {
        "operationId": "v1_process_create",
        "summary": "Full pipeline: transcribe, diarize, summarize",
        "tags": [
          "v1"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ProcessUpload"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/ProcessUpload"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessResponse"
                }
              }
            },
            "description": ""
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          },
          "413": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    },
    "/v1/transcribe": {
      "post": {
        "operationId": "v1_transcribe_create",
        "summary": "Transcribe audio file",
        "tags": [
          "v1"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/AudioUpload"
              }
            },
            "application/x-www-form-urlencoded": {
              "schema": {
                "$ref": "#/components/schemas/AudioUpload"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "oauth2": [
              "write"
            ]
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscribeResponse"
                }
              }
            },
            "description": ""
          },
          "400": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          },
          "413": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            },
            "description": ""
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AudioUpload": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "uri",
            "description": "Audio file (.wav, .mp3, .flac, .ogg, .m4a, .wma, .webm)"
          },
          "model": {
            "type": "string",
            "default": "small",
            "description": "Whisper model name"
          }
        },
        "required": [
          "file"
        ]
      },
      "BackendTypeEnum": {
        "enum": [
          "local",
          "s3"
        ],
        "type": "string",
        "description": "* `local` - Local Filesystem\n* `s3` - S3-compatible"
      },
      "DiarizeResponse": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "diarized_text": {
            "type": "string"
          },
          "segments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DiarizedSegment"
            }
          }
        },
        "required": [
          "diarized_text",
          "segments",
          "text"
        ]
      },
      "DiarizedSegment": {
        "type": "object",
        "properties": {
          "speaker": {
            "type": "string"
          },
          "start": {
            "type": "number",
            "format": "double"
          },
          "end": {
            "type": "number",
            "format": "double"
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "end",
          "speaker",
          "start",
          "text"
        ]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "detail": {
            "type": "string"
          }
        },
        "required": [
          "detail"
        ]
      },
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ]
      },
      "JobDetail": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "job_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "original_filename": {
            "type": "string"
          },
          "whisper_model": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          },
          "result_text": {
            "type": "string"
          },
          "result_diarized_text": {
            "type": "string"
          },
          "result_structured_text": {
            "type": "string"
          },
          "result_summary": {
            "type": "string"
          },
          "result_segments_json": {
            "nullable": true
          },
          "error_message": {
            "type": "string"
          }
        },
        "required": [
          "created_at",
          "error_message",
          "id",
          "job_type",
          "original_filename",
          "result_diarized_text",
          "result_segments_json",
          "result_structured_text",
          "result_summary",
          "result_text",
          "status",
          "updated_at",
          "whisper_model"
        ]
      },
      "JobResponse": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "job_type": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "original_filename": {
            "type": "string"
          },
          "whisper_model": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "created_at",
          "id",
          "job_type",
          "original_filename",
          "status",
          "updated_at",
          "whisper_model"
        ]
      },
      "ProcessResponse": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          },
          "diarized_text": {
            "type": "string",
            "nullable": true
          },
          "structured_text": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        },
        "required": [
          "diarized_text",
          "structured_text",
          "summary",
          "text"
        ]
      },
      "ProcessUpload": {
        "type": "object",
        "properties": {
          "file": {
            "type": "string",
            "format": "uri",
            "description": "Audio file (.wav, .mp3, .flac, .ogg, .m4a, .wma, .webm)"
          },
          "model": {
            "type": "string",
            "default": "small",
            "description": "Whisper model name"
          },
          "diarize": {
            "type": "boolean",
            "default": true,
            "description": "Enable speaker diarization"
          }
        },
        "required": [
          "file"
        ]
      },
      "StatusEnum": {
        "enum": [
          "success",
          "error"
        ],
        "type": "string",
        "description": "* `success` - success\n* `error` - error"
      },
      "StorageConfig": {
        "type": "object",
        "description": "Serializer for StorageConfig CRUD operations.\n\ns3_secret_key is write-only \u2014 never returned in API responses.",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "readOnly": true
          },
          "name": {
            "type": "string",
            "description": "Display name for this backend",
            "maxLength": 200
          },
          "backend_type": {
            "$ref": "#/components/schemas/BackendTypeEnum"
          },
          "is_default": {
            "type": "boolean",
            "description": "Use as default storage for new jobs"
          },
          "base_path": {
            "type": "string",
            "description": "Base path / prefix for stored files",
            "maxLength": 1024
          },
          "s3_endpoint_url": {
            "type": "string",
            "format": "uri",
            "maxLength": 200
          },
          "s3_bucket": {
            "type": "string",
            "maxLength": 255
          },
          "s3_access_key": {
            "type": "string",
            "maxLength": 255
          },
          "s3_secret_key": {
            "type": "string",
            "writeOnly": true,
            "maxLength": 255
          },
          "s3_region": {
            "type": "string",
            "maxLength": 100
          },
          "encrypt_at_rest": {
            "type": "boolean",
            "description": "Encrypt stored files with AES-256-GCM before writing"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "readOnly": true
          }
        },
        "required": [
          "backend_type",
          "created_at",
          "id",
          "name",
          "updated_at"
        ]
      },
      "StorageTestResponse": {
        "type": "object",
        "description": "Response for the storage backend test endpoint.",
        "properties": {
          "status": {
            "$ref": "#/components/schemas/StatusEnum"
          },
          "checks": {
            "type": "object",
            "additionalProperties": {
              "type": "boolean"
            }
          },
          "message": {
            "type": "string"
          },
          "duration_ms": {
            "type": "integer"
          }
        },
        "required": [
          "checks",
          "duration_ms",
          "message",
          "status"
        ]
      },
      "TranscribeResponse": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ]
      }
    },
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "/o/token/",
            "scopes": {
              "read": "Read access to API resources",
              "write": "Write access (upload, process)"
            }
          },
          "authorizationCode": {
            "authorizationUrl": "/o/authorize/",
            "tokenUrl": "/o/token/",
            "scopes": {
              "read": "Read access to API resources",
              "write": "Write access (upload, process)"
            }
          }
        }
      }
    }
  }
}
